	"tokenColors": [
		{
			"name": "Regular",
			"scope": [
				"source"
			],
			"settings": {
				"foreground": "#c8cad1",
			}
		},
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.arguments"
			],
			"settings": {
				"foreground": "#676d72",
			}
		},
		{
			"name": "Parameter + Codeblock + Namespace",
			"scope": [
				"variable.parameter",
				"markup.fenced_code",
				"entity.name.scope-resolution",
				"entity.name.type.namespace",
			],
			"settings": {
				"foreground": "#f3a909",
			}
		},
		{
			"name": "String",
			"scope": [
				"punctuation.definition.string.begin",
				"punctuation.definition.string.end",
				"string",
			],
			"settings": {
				"foreground": "#f7d669",
			}
		},
		{
			"name": "Keyword + Link",
			"scope": [
				"keyword",
				"entity.name.function.operator",
				"storage",
				"variable.language.special.self",
				"variable.parameter.function.language.special.self",
				"meta.link",
				"entity.name.tag",
			],
			"settings": {
				"foreground": "#ff6798",
			}
		},
		{
			"name": "Number",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"foreground": "#d670d6",
			}
		},
		{
			"name": "Function + Class + Type + Heading",
			"scope": [
				"meta.class",
				"entity.name.function",
				"markup.heading",
				"support.type",
				"entity.name.type.class",
				"variable.other.object"
			],
			"settings": {
				"foreground": "#46d0f3",
			}
		},
		{
			"name": "Function Call",
			"scope": [
				"meta.function-call",
				"entity.name.function.call",
				"entity.name.function.member",
				"entity.name.variable.field",
				"variable.other.object.property",
				"entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#a3e441",
			}
		},
	]
}